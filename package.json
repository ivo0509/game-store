{
  "name": "game-store",
  "version": "1.0.0",
  "description": "Game Store App for selling and buying video games",
  "license": "ISC",
  "author": "Ivan Yordanov",
  "private": true,
  "type": "commonjs",
  "workspaces": [
    "gamestore-web",
    "gamestore-mobile",
    "gamestore-shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "mobile:build:apk": "npm --prefix gamestore-mobile exec -- eas build --platform android --profile preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "expo-router": "~56.2.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.1",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0"
  }
}
